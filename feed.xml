---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title }}</title>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <description>{{ site.description }}</description>
    <language>en-us</language>
    <atom:link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/rss+xml" />
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    {%- assign feed_pages = site.pages | where_exp: "p", "p.feed" | sort: "order" | reverse -%}
    {%- for p in feed_pages -%}
    <item>
      <title>{{ p.title | xml_escape }}</title>
      <link>{{ p.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ p.url | absolute_url }}</guid>
      <description>{{ p.description | default: site.description | xml_escape }}</description>
      <pubDate>{{ site.time | date_to_rfc822 }}</pubDate>
    </item>
    {%- endfor -%}
  </channel>
</rss>
